{
  "name": "r8y",
  "private": true,
  "packageManager": "bun@1.3.9",
  "version": "1.0.0",
  "scripts": {
    "dev": "bunx turbo run dev",
    "dev:web": "bunx turbo run dev --filter=@r8y/web",
    "dev:crawler": "bunx turbo run dev --filter=@r8y/live-crawler",
    "start:live-crawler": "bun run --cwd apps/live-crawler start",
    "db:studio": "bun run --cwd packages/theo-data db:studio",
    "check": "bunx turbo run check",
    "format": "bunx turbo run format",
    "format:check": "prettier --check . --ignore-path .prettierignore",
    "test": "bunx turbo run test",
    "build": "bunx turbo run build"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.4.0",
    "turbo": "^2.8.20",
    "typescript": "^5.9.3"
  }
}
